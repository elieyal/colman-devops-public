server_name: eli-test
env: prod

vpc_name: eli-vpc
subnet_name: eli-subnet
subnet_cidr: 10.10.0.0/24
env_name: prod

# GCP Configuration
gcp_project: test01-eyaleli
gcp_region: me-west1
gcp_zone: me-west1-a
gcp_auth_kind: serviceaccount
gcp_cred_file: ./service_account.json

# Ubuntu 22.04 LTS image
gcp_ubuntu_image: projects/ubuntu-os-cloud/global/images/family/ubuntu-2204-lts
machine_type: e2-micro
server_volume_size: 10

# SSH public key content (paste your public key here)
ssh_public_key: "ssh-rsa "

# SSH private key file path
ssh_private_key_file: ~/.ssh/id_rsa
